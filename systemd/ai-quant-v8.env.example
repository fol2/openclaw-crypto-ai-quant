# OpenClaw AI Quant - v8 Parallel Instance (paper)
#
# Copy to: ~/.config/openclaw/ai-quant-v8.env
#
# Notes:
# - This file is intended for a separate v8 instance running from a `major-v8` worktree.
# - Do not point production services at this file.

# ── Notifications ─────────────────────────────────────────────────
# Discord channel ID for v8 paper trade notifications.
AI_QUANT_DISCORD_CHANNEL=1471091333161549999
# Dormant factory summary target channel (used only when the factory contract is re-enabled).
AI_QUANT_FACTORY_DISCORD_TARGET=
AI_QUANT_FACTORY_ENABLE=0

# Optional: alert fan-out (AQC-904).
# Example:
# AI_QUANT_ALERT_TARGETS=discord:1471091333161549999

# ── Risk / Ops ───────────────────────────────────────────────────
# Optional kill-switch file for manual pausing.
AI_QUANT_KILL_SWITCH_FILE=./artifacts/state/kill_switch_v8.txt

# Keep logs bounded via the runtime log-pruning service (timer reads this env var).
AI_QUANT_RUNTIME_LOG_KEEP_DAYS=14

# Persist kernel runtime state outside repo/worktree.
AI_QUANT_KERNEL_STATE_DIR=~/.mei

# Funding data check tuning (used by release validation and any future factory reactivation path).
# Fail threshold: abort only when stale symbols are older than this value.
AI_QUANT_FUNDING_MAX_AGE_FAIL_HOURS=24

# Stale-symbol allowance: 1 means one isolated stale symbol will degrade to WARN.
AI_QUANT_FUNDING_MAX_STALE_SYMBOLS=1
