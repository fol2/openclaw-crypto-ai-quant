# OpenClaw AI Quant - v8 Live Environment
#
# Used by: openclaw-ai-quant-live-v8.service
# Copy to ~/.config/openclaw/ai-quant-live-v8.env

# ── Secrets / Wallet ──────────────────────────────────────────────
# Recommended: keep secrets outside the repo and lock permissions (chmod 600).
AI_QUANT_SECRETS_PATH=~/.config/openclaw/ai-quant-secrets.json

# ── Live Safety Gates ─────────────────────────────────────────────
# Both MUST be set for live mode to send real orders.
# AI_QUANT_LIVE_ENABLE=1
# AI_QUANT_LIVE_CONFIRM=I_UNDERSTAND_THIS_CAN_LOSE_MONEY

# Kill switches (set to 1 to disable).
AI_QUANT_KILL_SWITCH=0
AI_QUANT_HARD_KILL_SWITCH=0

# ── Notifications ─────────────────────────────────────────────────
AI_QUANT_NOTIFY_DISCORD_LIVE=1
AI_QUANT_DISCORD_CHANNEL_LIVE=YOUR_DISCORD_CHANNEL_ID
AI_QUANT_DISCORD_LABEL=v8-LIVE

# ── Live Sizing ───────────────────────────────────────────────────
AI_QUANT_LIVE_MAX_OPEN_POSITIONS=10
AI_QUANT_LIVE_MAX_NOTIONAL_USD_PER_ORDER=150.0
AI_QUANT_LIVE_MIN_MARGIN_USD=8.0

# ── Runtime Behaviour ─────────────────────────────────────────────
AI_QUANT_LIVE_STATE_SYNC_SECS=20
AI_QUANT_LIVE_REST_FILLS_SYNC_SECS=300
AI_QUANT_HL_TIMEOUT_S=4
HL_LIVE_MARKET_SLIPPAGE_PCT=0.01
